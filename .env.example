# --- Database ---
DATABASE_URL="postgresql://booking:booking@localhost:5432/booking?schema=public"

# --- Web server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Reservation behaviour ---
RESERVATION_TTL_MINUTES=10
SLOT_MATERIALIZATION_WEEKS=8

# --- Payments (set real sandbox keys before exercising live Pix/card) ---
PAYMENT_PROVIDER=abacatepay          # or mercadopago
PAYMENT_API_KEY=__set_me__
PAYMENT_WEBHOOK_SECRET=__set_me__
PAYMENT_API_BASE_URL=https://api.abacatepay.com
DEFAULT_PRICE_CENTS=15000            # R$150.00

# --- Admin auth (shared secret for M1) ---
ADMIN_API_KEY=__set_me__

# --- Hardening ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60          # 0 disables (used by the load-test job)
TRUST_PROXY=false         # true on Railway/Render (behind a proxy)
FORCE_HTTPS=false         # true in production
